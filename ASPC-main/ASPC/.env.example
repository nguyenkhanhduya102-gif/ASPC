# Sao chép file này thành .env và điền vào thông tin thực tế của bạn
# Copy this file to .env and fill in your actual credentials

# ============================================================
#  MQTT BROKER CONFIGURATION
# ============================================================
MQTT_BROKER=your-broker-url.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=your_username
MQTT_PASSWORD=your_password
MQTT_TOPIC_SUB=aspc/data
MQTT_TOPIC_PUB=aspc/control

# ============================================================
#  APPLICATION SETTINGS
# ============================================================
# Chạy server ở địa chỉ và port nào?
HOST=0.0.0.0
PORT=5000

# Chế độ giả lập (True/False) - Dùng khi không có phần cứng thực
SIMULATION_MODE=False

# Secret key Flask (thay bằng chuỗi ngẫu nhiên dài)
SECRET_KEY=change-this-to-a-random-secret-key
